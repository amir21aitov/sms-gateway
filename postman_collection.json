{
	"info": {
		"name": "SMS Gateway API",
		"description": "Коллекция для SMS Gateway API.\n\nПеред использованием установите переменные коллекции:\n- `base_url` — адрес сервера (по умолчанию http://localhost:8000)\n- `admin_token` — токен для управления проектами (из .env ADMIN_TOKEN)\n- `api_key` — API ключ проекта (получается при создании проекта через POST /api/projects)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "admin_token",
			"value": "sms-gateway-admin-secret-token",
			"type": "string"
		},
		{
			"key": "api_key",
			"value": "YOUR_API_KEY_HERE",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Projects",
			"auth": {
				"type": "bearer",
				"bearer": [
					{
						"key": "token",
						"value": "{{admin_token}}",
						"type": "string"
					}
				]
			},
			"item": [
				{
					"name": "List projects",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/projects",
							"host": ["{{base_url}}"],
							"path": ["api", "projects"]
						},
						"description": "Получение списка всех проектов с пагинацией."
					},
					"response": []
				},
				{
					"name": "List projects (with pagination)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/projects?per_page=5&page=1",
							"host": ["{{base_url}}"],
							"path": ["api", "projects"],
							"query": [
								{
									"key": "per_page",
									"value": "5"
								},
								{
									"key": "page",
									"value": "1"
								}
							]
						},
						"description": "Список проектов с пагинацией."
					},
					"response": []
				},
				{
					"name": "Create project (Fake provider)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.api_key) {",
									"    pm.collectionVariables.set('api_key', jsonData.data.api_key);",
									"    console.log('api_key saved: ' + jsonData.data.api_key);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test Project\",\n    \"description\": \"Development project using fake SMS provider\",\n    \"provider\": \"fake\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/projects",
							"host": ["{{base_url}}"],
							"path": ["api", "projects"]
						},
						"description": "Создание проекта с Fake-провайдером. После выполнения api_key автоматически сохраняется в переменную коллекции."
					},
					"response": []
				},
